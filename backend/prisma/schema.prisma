generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(uuid())
  supabaseId String   @unique @map("supabase_id")
  email      String   @unique
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  transactions      Transaction[]
  categories        Category[]
  filterPreferences FilterPreferences?

  @@map("users")
}

model Transaction {
  id          String          @id @default(uuid())
  userId      String          @map("user_id")
  categoryId  String?         @map("category_id")
  hash        String          @unique
  date        DateTime
  description String
  amount      Decimal         @db.Decimal(12, 2)
  type        TransactionType
  account     String
  subcategory String?
  note        String?
  isPointed   Boolean         @default(false) @map("is_pointed")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id])

  @@index([userId])
  @@index([userId, date])
  @@index([type])
  @@map("transactions")
}

model Category {
  id        String          @id @default(uuid())
  userId    String          @map("user_id")
  name      String
  type      TransactionType
  createdAt DateTime        @default(now()) @map("created_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([userId, name, type])
  @@map("categories")
}

enum TransactionType {
  EXPENSE
  INCOME
}

model FilterPreferences {
  id                      String   @id @default(uuid())
  userId                  String   @unique @map("user_id")
  jointAccounts           String[] @default([]) @map("joint_accounts")
  hiddenExpenseCategories String[] @default([]) @map("hidden_expense_categories")
  hiddenIncomeCategories  String[] @default([]) @map("hidden_income_categories")
  categoryAssociations    Json     @default("[]") @map("category_associations")
  isPanelExpanded         Boolean  @default(true) @map("is_panel_expanded")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("filter_preferences")
}
