generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["app"]
}

model User {
  id         String   @id @default(uuid())
  supabaseId String   @unique @map("supabase_id")
  email      String   @unique
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  transactions          Transaction[]
  categories            Category[]
  filterPreferences     FilterPreferences?
  persons               Person[]
  reimbursementRequests ReimbursementRequest[]
  importHistories       ImportHistory[]
  settlements           Settlement[]
  categoryAssociations  CategoryAssociation[]

  @@map("users")
  @@schema("app")
}

model Transaction {
  id              String          @id @default(uuid())
  userId          String          @map("user_id")
  categoryId      String?         @map("category_id")
  importHistoryId String?         @map("import_history_id")
  hash            String          @unique
  date            DateTime
  description     String
  amount          Decimal         @db.Decimal(12, 2)
  type            TransactionType
  account         String
  subcategory     String?
  note            String?
  isPointed       Boolean         @default(false) @map("is_pointed")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  category              Category?              @relation(fields: [categoryId], references: [id])
  importHistory         ImportHistory?         @relation(fields: [importHistoryId], references: [id], onDelete: SetNull)
  reimbursementRequests ReimbursementRequest[]
  settlementsAsIncome   Settlement[]           @relation("SettlementIncome")

  @@index([userId])
  @@index([userId, date])
  @@index([type])
  @@index([importHistoryId])
  @@map("transactions")
  @@schema("app")
}

model Category {
  id        String          @id @default(uuid())
  userId    String          @map("user_id")
  name      String
  type      TransactionType
  createdAt DateTime        @default(now()) @map("created_at")

  user                        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions                Transaction[]
  reimbursementRequests       ReimbursementRequest[]
  expenseCategoryAssociations CategoryAssociation[]  @relation("ExpenseCategory")
  incomeCategoryAssociations  CategoryAssociation[]  @relation("IncomeCategory")

  @@unique([userId, name, type])
  @@map("categories")
  @@schema("app")
}

enum TransactionType {
  EXPENSE
  INCOME

  @@schema("app")
}

enum ReimbursementStatus {
  PENDING
  PARTIAL
  COMPLETED

  @@schema("app")
}

enum ImportStatus {
  IN_PROGRESS
  COMPLETED
  FAILED

  @@schema("app")
}

model FilterPreferences {
  id                      String   @id @default(uuid())
  userId                  String   @unique @map("user_id")
  jointAccounts           String[] @default([]) @map("joint_accounts")
  hiddenExpenseCategories String[] @default([]) @map("hidden_expense_categories")
  hiddenIncomeCategories  String[] @default([]) @map("hidden_income_categories")
  categoryAssociations    Json     @default("[]") @map("category_associations")
  isPanelExpanded         Boolean  @default(true) @map("is_panel_expanded")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("filter_preferences")
  @@schema("app")
}

model Person {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  email     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  reimbursementRequests ReimbursementRequest[]
  settlements           Settlement[]

  @@unique([userId, name])
  @@index([userId])
  @@map("persons")
  @@schema("app")
}

model ReimbursementRequest {
  id             String              @id @default(uuid())
  userId         String              @map("user_id")
  transactionId  String              @map("transaction_id")
  personId       String              @map("person_id")
  categoryId     String?             @map("category_id")
  amount         Decimal             @db.Decimal(12, 2)
  amountReceived Decimal             @default(0) @map("amount_received") @db.Decimal(12, 2)
  status         ReimbursementStatus @default(PENDING)
  note           String?
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  person      Person      @relation(fields: [personId], references: [id], onDelete: Cascade)
  category    Category?   @relation(fields: [categoryId], references: [id])
  settlements SettlementReimbursement[]

  @@index([userId])
  @@index([transactionId])
  @@index([personId])
  @@index([status])
  @@map("reimbursement_requests")
  @@schema("app")
}

model ImportHistory {
  id String @id @default(uuid())

  userId String @map("user_id")

  // Statut de l'import
  status ImportStatus @default(IN_PROGRESS)

  // Statistiques d'import
  transactionsImported Int @default(0) @map("transactions_imported")
  categoriesCreated    Int @default(0) @map("categories_created")
  duplicatesSkipped    Int @default(0) @map("duplicates_skipped")
  totalInFile          Int @map("total_in_file")

  // Plage de dates des transactions
  dateRangeStart DateTime? @map("date_range_start")
  dateRangeEnd   DateTime? @map("date_range_end")

  // Métadonnées
  accounts String[] @default([])
  fileName String?  @map("file_name")

  createdAt DateTime @default(now()) @map("created_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
  @@index([userId, createdAt])
  @@index([status])
  @@map("import_histories")
  @@schema("app")
}

model Settlement {
  id                  String   @id @default(uuid())
  userId              String   @map("user_id")
  personId            String   @map("person_id")
  incomeTransactionId String   @map("income_transaction_id")
  amountUsed          Decimal  @map("amount_used") @db.Decimal(12, 2)
  note                String?
  createdAt           DateTime @default(now()) @map("created_at")

  user              User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  person            Person                    @relation(fields: [personId], references: [id], onDelete: Cascade)
  incomeTransaction Transaction               @relation("SettlementIncome", fields: [incomeTransactionId], references: [id], onDelete: Cascade)
  reimbursements    SettlementReimbursement[]

  @@index([userId])
  @@index([personId])
  @@index([incomeTransactionId])
  @@map("settlements")
  @@schema("app")
}

model SettlementReimbursement {
  id              String  @id @default(uuid())
  settlementId    String  @map("settlement_id")
  reimbursementId String  @map("reimbursement_id")
  amountSettled   Decimal @map("amount_settled") @db.Decimal(12, 2)

  settlement    Settlement           @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  reimbursement ReimbursementRequest @relation(fields: [reimbursementId], references: [id], onDelete: Cascade)

  @@unique([settlementId, reimbursementId])
  @@index([reimbursementId])
  @@map("settlement_reimbursements")
  @@schema("app")
}

model CategoryAssociation {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  expenseCategoryId String   @map("expense_category_id")
  incomeCategoryId  String   @map("income_category_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenseCategory Category @relation("ExpenseCategory", fields: [expenseCategoryId], references: [id], onDelete: Cascade)
  incomeCategory  Category @relation("IncomeCategory", fields: [incomeCategoryId], references: [id], onDelete: Cascade)

  @@unique([userId, expenseCategoryId])
  @@unique([userId, incomeCategoryId])
  @@index([userId])
  @@map("category_associations")
  @@schema("app")
}
