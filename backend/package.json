{
  "name": "backend",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build": "nest build",
    "build:vercel": "pnpm prisma:generate && pnpm prisma:deploy && pnpm build",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "prisma:generate": "prisma generate --config prisma/prisma.config.ts",
    "prisma:migrate": "prisma migrate dev --config prisma/prisma.config.ts",
    "prisma:deploy": "prisma migrate deploy --config prisma/prisma.config.ts",
    "prisma:studio": "prisma studio --config prisma/prisma.config.ts"
  },
  "dependencies": {
    "@langchain/anthropic": "1.3.25",
    "@langchain/core": "1.1.34",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "4.0.3",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "11.2.6",
    "@prisma/adapter-pg": "7.4.2",
    "@prisma/client": "7.4.2",
    "@supabase/supabase-js": "2.98.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "dotenv": "17.3.1",
    "langchain": "1.2.35",
    "pg": "8.19.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@swc/core": "1.15.18",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "8.18.0",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "4.0.18",
    "decimal.js": "10.6.0",
    "prisma": "7.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "7.2.2",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.0",
    "unplugin-swc": "1.5.9",
    "vitest": "^4.0.18"
  }
}
